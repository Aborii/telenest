# ─────────────────────────────────────────────────────────────────────────────
# BOT API (Telegraf) — for running a normal Telegram bot
# Get a token from @BotFather.
# ─────────────────────────────────────────────────────────────────────────────

# Token for the example "echo" bot (required to run the demo app)
ECHO_BOT_TOKEN=123456:echo-token

# Token for the example "greeter" bot (required to run the demo app)
GREETER_BOT_TOKEN=123456:greeter-token

# Enable webhook mode for the echo bot (optional)
ECHO_BOT_WEBHOOK_DOMAIN=
ECHO_BOT_WEBHOOK_PATH=/telegram/echo

# Enable webhook mode for the greeter bot (optional)
GREETER_BOT_WEBHOOK_DOMAIN=
GREETER_BOT_WEBHOOK_PATH=/telegram/greeter

# ─────────────────────────────────────────────────────────────────────────────
# MTProto USER ACCOUNT (GramJS) — for signing in with your OWN account
# Create an application at https://my.telegram.org → "API development tools"
# to obtain api_id and api_hash. Treat TG_SESSION like a password.
# ─────────────────────────────────────────────────────────────────────────────

# Application api_id (a number)
TG_API_ID=

# Application api_hash (a hex string)
TG_API_HASH=

# Your account phone number in international format (used by the login CLI)
TG_PHONE=

# Saved string session produced after a successful login (empty on first run)
TG_SESSION=
