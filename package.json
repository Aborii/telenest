{
  "name": "telenest",
  "version": "1.3.0",
  "description": "Fully-typed NestJS module for Telegram: the Bot API (via Telegraf) and the MTProto user-account client (via GramJS). Send/receive as a bot, or sign in with your own account and control it from your app.",
  "license": "MIT",
  "author": "Abdullah Almofleh <118676821+Aborii@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aborii/nestjs-telegram.git"
  },
  "bugs": {
    "url": "https://github.com/Aborii/nestjs-telegram/issues"
  },
  "homepage": "https://github.com/Aborii/nestjs-telegram#readme",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bot": {
      "types": "./dist/lib/bot/index.d.ts",
      "default": "./dist/lib/bot/index.js"
    },
    "./client": {
      "types": "./dist/lib/client/index.d.ts",
      "default": "./dist/lib/client/index.js"
    },
    "./common": {
      "types": "./dist/lib/common/index.d.ts",
      "default": "./dist/lib/common/index.js"
    },
    "./testing": {
      "types": "./dist/lib/testing/index.d.ts",
      "default": "./dist/lib/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "bot": [
        "dist/lib/bot/index.d.ts"
      ],
      "client": [
        "dist/lib/client/index.d.ts"
      ],
      "common": [
        "dist/lib/common/index.d.ts"
      ],
      "testing": [
        "dist/lib/testing/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "nestjs",
    "telegram",
    "telegraf",
    "gramjs",
    "mtproto",
    "bot",
    "userbot",
    "telegram-client"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start:dev": "ts-node -P tsconfig.json src/main.ts",
    "login": "ts-node -P tsconfig.json examples/login-cli.ts",
    "lint": "eslint \"{src,test,examples}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test,examples}/**/*.ts\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "git:release": "node scripts/release.mts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0",
    "telegraf": "^4.16.0",
    "telegram": "^2.26.0"
  },
  "peerDependenciesMeta": {
    "telegraf": {
      "optional": true
    },
    "telegram": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "big-integer": "^1.6.52"
  },
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "big-integer": "^1.6.52",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^30.4.2",
    "nestjs-telegraf": "^2.9.1",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22",
    "ts-jest": "^29.4.10",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  }
}
